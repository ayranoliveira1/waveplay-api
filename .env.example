# App
PORT=3333
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5438/waveplay

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=48h

# TMDB
TMDB_ACCESS_TOKEN=
TMDB_BASE_URL=https://api.themoviedb.org/3

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (Gmail OAuth2)
EMAIL_USER=
EMAIL_CLIENT_ID=
EMAIL_CLIENT_SECRET=
EMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
EMAIL_REFRESH_TOKEN=

# Frontend
FRONTEND_URL=http://localhost:3000

# Feature flags
# Cadastro publico (POST /auth/register). Setar "true" para habilitar.
REGISTRATION_ENABLED=false
